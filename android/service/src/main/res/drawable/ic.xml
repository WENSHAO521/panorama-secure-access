<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:width="240dp"
    android:height="240dp"
    android:viewportWidth="240"
    android:viewportHeight="240"
    tools:ignore="VectorRaster">

    <!--
        Quick Settings tile icon — panorama security design.
        Scaled from 200×200 to 240×240 (factor 1.2), center at (120, 120).
        Stroke width = 8 × 1.2 = 9.6.
    -->

    <!-- Outer arc: radius 60 → 72 -->
    <path android:pathData="M48,120 A72,72 0 0,1 192,120"
          android:strokeColor="#FFFFFF"
          android:strokeWidth="9.6"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>

    <!-- Middle arc: radius 45 → 54 -->
    <path android:pathData="M66,120 A54,54 0 0,1 174,120"
          android:strokeColor="#FFFFFF"
          android:strokeWidth="9.6"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>

    <!-- Inner arc: radius 30 → 36 -->
    <path android:pathData="M84,120 A36,36 0 0,1 156,120"
          android:strokeColor="#FFFFFF"
          android:strokeWidth="9.6"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>

    <!-- Secure-access pillar -->
    <path android:pathData="M112.8,96 H127.2 V168 H112.8 Z"
          android:fillColor="#FFFFFF"/>

    <!-- Base line -->
    <path android:pathData="M48,174 H192 V178.8 H48 Z"
          android:fillColor="#FFFFFF"/>

</vector>
